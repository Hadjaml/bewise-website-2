    "method": {
      "eyebrow": "Notre méthode",
      "title": "Notre méthode en 3 étapes",
      "steps": [
        {
          "title": "Cartographie",
          "text": "Nous analysons vos processus, vos outils et les points où vos équipes perdent le plus de temps."
        },
        {
          "title": "Prototype",
          "text": "Nous construisons un premier agent IA sur mesure, relié à vos données et testé sur un cas d’usage concret."
        },
        {
          "title": "Déploiement",
          "text": "Nous formons vos équipes, suivons les gains et améliorons les agents au fil de vos usages réels."
        }
      ]
    },
    "agents": {
      "eyebrow": "Notre suite d’agents IA",
      "title": "Des agents spécialisés pour accélérer chaque fonction clé.",
      "highlight": "chaque fonction clé",
      "intro": "Chaque agent s’intègre à vos outils et s’adapte à vos processus métiers. Ensemble, ils réduisent les tâches manuelles, fluidifient les échanges et rendent vos opérations plus mesurables.",
