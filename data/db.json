    "faq": {
      "eyebrow": "Questions fréquentes",
      "title": "Questions fréquentes",
      "items": [
        {
          "question": "Nous avons déjà des outils métier.",
          "answer": "Parfait. Nos agents viennent les compléter, pas les remplacer."
        },
        {
          "question": "Combien de temps dure un projet ?",
          "answer": "2 à 6 semaines selon les besoins."
        },
        {
          "question": "Est-ce adapté à une PME ?",
          "answer": "Oui. Nous dimensionnons les agents selon votre volume d’activité, votre équipe et vos priorités."
        },
        {
          "question": "Faut-il une équipe technique en interne ?",
          "answer": "Non. Nous cadrons, développons et accompagnons le déploiement avec vos équipes métiers."
        },
        {
          "question": "Les agents sont-ils personnalisés ?",
          "answer": "Toujours. Chaque agent est construit autour de vos processus, de vos outils et de votre façon de travailler."
        }
      ]
    },
